# Per-machine default identity (untracked). install.sh creates a template.
# On the work Mac set this to the work email; on personal, the gmail.
[include]
	path = ~/.gitconfig-local
[user]
	name = Charan Ganesh
# Any repo whose remote is github.com/charanganesh/* uses the personal
# identity, regardless of where it lives on disk or the machine default above.
[includeIf "hasconfig:remote.*.url:**charanganesh/**"]
	path = ~/.gitconfig-personal
[core]
	excludesfile = /Users/charan.ganesh/.gitignore_global
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[commit]
	template = /Users/charan.ganesh/.stCommitMsg
